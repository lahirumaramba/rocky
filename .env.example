# Gemini API Key - Get yours from https://aistudio.google.com/
GEMINI_API_KEY=

# Local LLM Configuration
USE_LOCAL_LLM=False
LM_STUDIO_URL=http://localhost:1234/v1
LOCAL_MODEL_ID=gemma-4-e2b

# UI Configuration
